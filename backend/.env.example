# Local backend environment file example.
# Copy this to backend/.env for local testing only.
# Do NOT commit backend/.env to GitHub.

FINNHUB_API_KEY=your_finnhub_key_here
TWELVE_DATA_API_KEY=
OPENAI_API_KEY=

PAPER_TRADING_DATA_DIR=./data
NODE_ENV=development
SERVE_FRONTEND=false

QUOTE_CACHE_MS=300000
CLOSED_MARKET_QUOTE_CACHE_MS=3600000
NEWS_CACHE_MS=900000
FINNHUB_REQUEST_DELAY_MS=250

# Leave false/unset for real simulator behavior. Set true only for local testing outside market hours.
PAPER_TRADING_IGNORE_MARKET_HOURS=false
